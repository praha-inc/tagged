{
  "name": "@praha/tagged",
  "version": "1.0.0",
  "description": "Lightweight TypeScript tagged union (discriminated union) utilities.",
  "keywords": [
    "javascript",
    "typescript",
    "tagged",
    "discriminated",
    "union"
  ],
  "homepage": "https://github.com/praha-inc/tagged/blob/main/README.md",
  "bugs": {
    "url": "https://github.com/praha-inc/tagged/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/praha-inc/tagged.git"
  },
  "license": "MIT",
  "author": "PrAha, Inc.",
  "sideEffects": false,
  "type": "module",
  "exports": {
    "require": {
      "types": "./dist/cjs/index.d.ts",
      "default": "./dist/cjs/index.cjs"
    },
    "import": {
      "types": "./dist/esm/index.d.ts",
      "default": "./dist/esm/index.js"
    }
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rslib build",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint:code": "oxlint",
    "lint:type": "tsc --noEmit",
    "version": "changeset",
    "version:apply": "changeset version",
    "version:publish": "changeset publish",
    "version:prepublish": "pkg-pr-new publish --pnpm --compact"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@praha/oxlint-config-standard": "1.0.0-beta.1",
    "@rslib/core": "0.20.0",
    "@tsconfig/strictest": "2.0.8",
    "oxlint": "1.56.0",
    "pkg-pr-new": "0.0.66",
    "typescript": "5.9.3",
    "vitest": "4.1.1"
  },
  "packageManager": "pnpm@10.32.1",
  "publishConfig": {
    "provenance": true
  }
}
